{
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "vLLM Benchmark Suite — real-time inference performance monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Throughput (tokens/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(vllm:generation_tokens_total[1m])",
          "legendFormat": "Generation tok/s"
        },
        {
          "expr": "rate(vllm:prompt_tokens_total[1m])",
          "legendFormat": "Prompt tok/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Request Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vllm:e2e_request_latency_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.90, rate(vllm:e2e_request_latency_seconds_bucket[5m]))",
          "legendFormat": "P90"
        },
        {
          "expr": "histogram_quantile(0.99, rate(vllm:e2e_request_latency_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Time to First Token",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vllm:time_to_first_token_seconds_bucket[5m]))",
          "legendFormat": "TTFT P50"
        },
        {
          "expr": "histogram_quantile(0.90, rate(vllm:time_to_first_token_seconds_bucket[5m]))",
          "legendFormat": "TTFT P90"
        },
        {
          "expr": "histogram_quantile(0.99, rate(vllm:time_to_first_token_seconds_bucket[5m]))",
          "legendFormat": "TTFT P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "orange", "value": 1.0 },
              { "color": "red", "value": 3.0 }
            ]
          }
        }
      }
    },
    {
      "title": "Inter-Token Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vllm:time_per_output_token_seconds_bucket[5m]))",
          "legendFormat": "ITL P50"
        },
        {
          "expr": "histogram_quantile(0.90, rate(vllm:time_per_output_token_seconds_bucket[5m]))",
          "legendFormat": "ITL P90"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Concurrent Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "vllm:num_requests_running",
          "legendFormat": "Running"
        },
        {
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "Waiting"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "KV Cache Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "vllm:gpu_cache_usage_perc * 100",
          "legendFormat": "GPU KV Cache %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "Prefix Cache Hit Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "rate(vllm:prefix_cache_hits_total[5m]) / (rate(vllm:prefix_cache_queries_total[5m]) + 1e-10) * 100",
          "legendFormat": "Hit Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 70 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "GPU Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED / (1024*1024*1024)",
          "legendFormat": "Used GB (GPU {{gpu}})"
        },
        {
          "expr": "DCGM_FI_DEV_FB_FREE / (1024*1024*1024)",
          "legendFormat": "Free GB (GPU {{gpu}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "GPU Temperature & Power",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "Temp °C (GPU {{gpu}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Power Draw",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "Watts (GPU {{gpu}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "rate(vllm:request_success_total[5m])",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Active LoRA Adapters",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 40 },
      "targets": [
        {
          "expr": "vllm:num_requests_running",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "title": "Avg Prefill Time",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 40 },
      "targets": [
        {
          "expr": "rate(vllm:request_prefill_time_seconds_sum[5m]) / rate(vllm:request_prefill_time_seconds_count[5m])",
          "legendFormat": "Prefill"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Avg Decode Time",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 40 },
      "targets": [
        {
          "expr": "rate(vllm:request_decode_time_seconds_sum[5m]) / rate(vllm:request_decode_time_seconds_count[5m])",
          "legendFormat": "Decode"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["vllm", "benchmark", "inference", "gpu"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "vLLM Performance Dashboard",
  "uid": "vllm-benchmark-suite",
  "version": 1
}
